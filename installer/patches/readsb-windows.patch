index 0000000..3eaee69
--- /dev/null
+++ b/compat/windows/net_init.c
@@ -0,0 +1,18 @@
+/*
+ * compat/windows/net_init.c — one real, linked TU so the WSAStartup constructor actually
+ * fires at process start (a static-inline constructor in net_compat.h is discarded).
+ */
+#include "net_compat.h"
+
+static int win_wsa_started = 0;
+
+void win_net_init(void) {
+	if (!win_wsa_started) {
+		WSADATA w;
+		WSAStartup(MAKEWORD(2, 2), &w);
+		win_wsa_started = 1;
+	}
+}
+
+__attribute__((constructor))
+static void win_net_ctor(void) { win_net_init(); }
