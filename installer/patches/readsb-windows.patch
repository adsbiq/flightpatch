diff --git a/compat/windows/sys_compat.h b/compat/windows/sys_compat.h
new file mode 100644
index 0000000..534391d
--- /dev/null
+++ b/compat/windows/sys_compat.h
@@ -0,0 +1,197 @@
+/*
+ * compat/windows/sys_compat.h — POSIX signals / priority / CPU-affinity / *_r time
+ * shims for native Windows (mingw). readsb's startup code (readsb.c) uses these Linux
+ * facilities; Windows lacks most, so we map or stub them. (Same idea as the apple compat.)
+ */
+#ifndef WIN_SYS_COMPAT_H
+#define WIN_SYS_COMPAT_H
+
+#include <signal.h>
+#include <time.h>
+#include <stddef.h>
+#include <windows.h>
+
+/* ---- POSIX signals Windows lacks (define as harmless numbers) ---- */
+#ifndef SIGHUP
+#define SIGHUP 1
+#endif
+#ifndef SIGQUIT
+#define SIGQUIT 3
+#endif
+#ifndef SIGKILL
+#define SIGKILL 9
+#endif
+#ifndef SIGUSR1
+#define SIGUSR1 10
+#endif
+#ifndef SIGUSR2
+#define SIGUSR2 12
+#endif
+#ifndef SIGPIPE
+#define SIGPIPE 13
+#endif
+#ifndef SIGCHLD
+#define SIGCHLD 17
+#endif
+#ifndef SIGSTOP
+#define SIGSTOP 19
+#endif
+#ifndef SIGCONT
+#define SIGCONT 18
+#endif
+
+/* ---- sigaction → route to signal() for the handlers Windows actually supports ---- */
+#ifndef WIN_HAVE_SIGSET_T
+typedef int win_sigset_t;
+#define sigset_t win_sigset_t
+#endif
+struct sigaction {
+	void (*sa_handler)(int);
+	sigset_t sa_mask;
+	int sa_flags;
+};
+static inline int sigemptyset(sigset_t *s) { if (s) *s = 0; return 0; }
+static inline int sigfillset(sigset_t *s) { if (s) *s = ~0; return 0; }
+static inline int sigaddset(sigset_t *s, int n) { (void) n; if (s) *s |= 1; return 0; }
+static inline int win_sigaction(int sig, const struct sigaction *act, struct sigaction *old) {
+	(void) old;
+	if (act && act->sa_handler && (sig == SIGINT || sig == SIGTERM || sig == SIGABRT))
+		signal(sig, act->sa_handler);
+	return 0;
+}
+#define sigaction(s, a, o) win_sigaction((s), (a), (o))
+
+/* ---- priority (nice): no-op; real Idle-priority is set via SetPriorityClass elsewhere ---- */
+#ifndef PRIO_PROCESS
+#define PRIO_PROCESS 0
+#endif
+static inline int getpriority(int which, int who) { (void) which; (void) who; return 0; }
+static inline int setpriority(int which, int who, int prio) { (void) which; (void) who; (void) prio; return 0; }
+
+/* ---- CPU affinity → report core count, ignore pinning ---- */
+typedef struct { int unused; } cpu_set_t;
+#ifndef CPU_SETSIZE
+#define CPU_SETSIZE 1024
+#endif
+static inline int win_ncpu(void) { SYSTEM_INFO si; GetSystemInfo(&si); return (int) si.dwNumberOfProcessors; }
+#define CPU_COUNT(set)      win_ncpu()
+#define CPU_ZERO(set)       ((void) 0)
+#define CPU_SET(cpu, set)   ((void) 0)
+#define CPU_CLR(cpu, set)   ((void) 0)
+#define CPU_ISSET(cpu, set) 1
+static inline int sched_getaffinity(int pid, size_t sz, cpu_set_t *set) { (void) pid; (void) sz; (void) set; return 0; }
+static inline int sched_setaffinity(int pid, size_t sz, const cpu_set_t *set) { (void) pid; (void) sz; (void) set; return 0; }
+
+/* ---- *_r time functions via Windows *_s ---- */
+#ifndef gmtime_r
+static inline struct tm *gmtime_r(const time_t *t, struct tm *out) { return gmtime_s(out, t) == 0 ? out : NULL; }
+#endif
+#ifndef localtime_r
+static inline struct tm *localtime_r(const time_t *t, struct tm *out) { return localtime_s(out, t) == 0 ? out : NULL; }
+#endif
+
+/* msvcrt strftime is C89-only (no %T/%F). Translate them, then call the real strftime.
+ * Defined before the macro, so this body binds the real strftime (no recursion). */
+static inline size_t win_strftime(char *s, size_t max, const char *fmt, const struct tm *tm) {
+	char f2[256];
+	size_t j = 0;
+	for (size_t i = 0; fmt[i] && j < sizeof(f2) - 12; i++) {
+		if (fmt[i] == '%' && fmt[i + 1] == 'T') { memcpy(f2 + j, "%H:%M:%S", 8); j += 8; i++; }
+		else if (fmt[i] == '%' && fmt[i + 1] == 'F') { memcpy(f2 + j, "%Y-%m-%d", 8); j += 8; i++; }
+		else f2[j++] = fmt[i];
+	}
+	f2[j] = 0;
+	return strftime(s, max, f2, tm);
+}
+#define strftime(s, max, fmt, tm) win_strftime((s), (max), (fmt), (tm))
+
+/* ---- BSD/GNU libc bits Windows lacks ---- */
+#include <direct.h>
+#include <string.h>
+#include <stdlib.h>
+
+#ifndef srandom
+#define srandom srand
+#endif
+#ifndef random
+#define random rand
+#endif
+
+/* POSIX mkdir(path, mode) → Windows _mkdir(path) (drops the mode) */
+#define mkdir(path, mode) _mkdir(path)
+
+static inline char *strcasestr(const char *hay, const char *needle) {
+	size_t nl = strlen(needle);
+	if (!nl) return (char *) hay;
+	for (; *hay; hay++)
+		if (_strnicmp(hay, needle, nl) == 0) return (char *) hay;
+	return NULL;
+}
+/* symlink/readlink: Windows symlinks need privilege; readsb uses them only for the
+ * tar1090 history dir layout (non-critical for feeding) → stub. */
+static inline int symlink(const char *target, const char *linkpath) { (void) target; (void) linkpath; return 0; }
+static inline int readlink(const char *path, char *buf, size_t len) { (void) path; (void) buf; (void) len; return -1; }
+
+/* POSIX rename() atomically overwrites the target; Windows rename() fails if the target
+ * exists ("File exists"). readsb relies on overwrite for its atomic JSON output (aircraft.json
+ * etc.), so route rename() through MoveFileEx with REPLACE_EXISTING. */
+#include <errno.h>
+static inline int win_rename(const char *from, const char *to) {
+	if (MoveFileExA(from, to, MOVEFILE_REPLACE_EXISTING)) return 0;
+	errno = EIO;
+	return -1;
+}
+#define rename(a, b) win_rename((a), (b))
+
+static inline char *strsignal(int s) { (void) s; return (char *) "signal"; }
+static inline int sigprocmask(int how, const sigset_t *set, sigset_t *old) {
+	(void) how; (void) set; (void) old; return 0;
+}
+
+/* timegm → Windows CRT UTC mktime */
+#ifndef timegm
+#define timegm _mkgmtime
+#endif
+
+/* (pthread_tryjoin_np not needed on Windows: threadSignalJoin uses the blocking-join path.) */
+
+/* strsep (BSD) */
+static inline char *strsep(char **stringp, const char *delim) {
+	char *start = *stringp, *p;
+	if (!start) return NULL;
+	p = start + strcspn(start, delim);
+	if (*p) { *p = '\0'; *stringp = p + 1; } else { *stringp = NULL; }
+	return start;
+}
+
+/* Minimal strptime — enough for readsb's SBS timestamp "%Y/%m/%d %H:%M:%S". */
+static inline char *strptime(const char *s, const char *fmt, struct tm *tm) {
+	while (*fmt) {
+		if (*fmt == '%') {
+			fmt++;
+			int val = 0, n = 0;
+			while (*s >= '0' && *s <= '9') { val = val * 10 + (*s++ - '0'); n++; }
+			if (*fmt != 'y' && n == 0) return NULL;
+			switch (*fmt) {
+			case 'Y': tm->tm_year = val - 1900; break;
+			case 'y': tm->tm_year = val < 69 ? val + 100 : val; break;
+			case 'm': tm->tm_mon = val - 1; break;
+			case 'd': tm->tm_mday = val; break;
+			case 'H': tm->tm_hour = val; break;
+			case 'M': tm->tm_min = val; break;
+			case 'S': tm->tm_sec = val; break;
+			default: return NULL; /* unsupported specifier */
+			}
+			fmt++;
+		} else if (*fmt == ' ') {
+			while (*s == ' ' || *s == '\t') s++;
+			fmt++;
+		} else {
+			if (*s != *fmt) return NULL;
+			s++; fmt++;
+		}
+	}
+	return (char *) s;
+}
+
+#endif /* WIN_SYS_COMPAT_H */
