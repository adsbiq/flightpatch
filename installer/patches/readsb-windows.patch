diff --git a/compat/windows/win_sockops.h b/compat/windows/win_sockops.h
new file mode 100644
index 0000000..01d658f
--- /dev/null
+++ b/compat/windows/win_sockops.h
@@ -0,0 +1,30 @@
+/*
+ * compat/windows/win_sockops.h — per-file POSIX-socket-op remapping for native Windows.
+ * Include ONLY in socket-pure TUs (anet.c, net_io.c, api.c) AFTER system includes.
+ * Non-socket exceptions (net_io.c uuidFile read, epoll-fd close) are patched in source
+ * with explicit _open/_read/_close / rsb_epoll_close so these macros don't apply there.
+ */
+#ifndef WIN_SOCKOPS_H
+#define WIN_SOCKOPS_H
+
+#include "net_compat.h"
+
+/* fcntl(fd, F_GETFL) / fcntl(fd, F_SETFL, flags|O_NONBLOCK) → ioctlsocket(FIONBIO) */
+#ifndef F_GETFL
+#define F_GETFL 3
+#endif
+#ifndef F_SETFL
+#define F_SETFL 4
+#endif
+/* variadic so both fcntl(fd,F_GETFL) and fcntl(fd,F_SETFL,flags) compile */
+static inline int win_fcntl(int fd, int cmd, ...) {
+    if (cmd == F_SETFL) return win_set_nonblock(fd);
+    return 0; /* F_GETFL: return 0; readsb ORs O_NONBLOCK then does F_SETFL */
+}
+
+#define close(fd)          win_closesocket(fd)
+#define read(fd, b, n)     win_recv((fd), (b), (n))
+#define write(fd, b, n)    win_send((fd), (b), (n))
+#define fcntl              win_fcntl
+
+#endif /* WIN_SOCKOPS_H */
