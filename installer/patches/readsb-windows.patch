diff --git a/compat/windows/epoll_shim.c b/compat/windows/epoll_shim.c
new file mode 100644
index 0000000..4273e82
--- /dev/null
+++ b/compat/windows/epoll_shim.c
@@ -0,0 +1,46 @@
+/*
+ * compat/windows/epoll_shim.c — int<->HANDLE bridge over wepoll.
+ * Compiled as its own TU (does NOT include epoll_shim.h, so the epoll_* macros do not
+ * apply here) and calls wepoll's real HANDLE-based epoll_* functions.
+ */
+#include "wepoll.h"
+#include <stddef.h>
+
+/* readsb creates very few epoll instances (net_epfd + one per api thread). A tiny fixed
+ * table is plenty and avoids any allocation. Index == the int "fd" we hand back. */
+#define RSB_MAX_EPFD 32
+static HANDLE g_eptab[RSB_MAX_EPFD];
+static int    g_epcount = 0;
+
+static int alloc_slot(HANDLE h) {
+    if (!h) return -1;
+    if (g_epcount >= RSB_MAX_EPFD) return -1;
+    int fd = g_epcount++;
+    g_eptab[fd] = h;
+    return fd;
+}
+
+int rsb_epoll_create(int size) {
+    return alloc_slot(epoll_create(size));
+}
+
+int rsb_epoll_create1(int flags) {
+    return alloc_slot(epoll_create1(flags));
+}
+
+int rsb_epoll_ctl(int epfd, int op, int sockfd, struct epoll_event *ev) {
+    if (epfd < 0 || epfd >= g_epcount || !g_eptab[epfd]) return -1;
+    return epoll_ctl(g_eptab[epfd], op, (SOCKET) (uintptr_t) sockfd, ev);
+}
+
+int rsb_epoll_wait(int epfd, struct epoll_event *events, int maxevents, int timeout) {
+    if (epfd < 0 || epfd >= g_epcount || !g_eptab[epfd]) return -1;
+    return epoll_wait(g_eptab[epfd], events, maxevents, timeout);
+}
+
+int rsb_epoll_close(int epfd) {
+    if (epfd < 0 || epfd >= g_epcount || !g_eptab[epfd]) return -1;
+    int r = epoll_close(g_eptab[epfd]);
+    g_eptab[epfd] = NULL;
+    return r;
+}
diff --git a/compat/windows/epoll_shim.h b/compat/windows/epoll_shim.h
new file mode 100644
index 0000000..fe10f13
--- /dev/null
+++ b/compat/windows/epoll_shim.h
@@ -0,0 +1,38 @@
+/*
+ * compat/windows/epoll_shim.h — native Windows (mingw-w64) epoll for readsb.
+ *
+ * readsb uses a POSIX int-based epoll API (int epfd, int socket fds). Windows has no
+ * epoll; we back it with wepoll (IOCP/AFD), whose epoll handle is a HANDLE and whose
+ * sockets are SOCKET. This header keeps readsb's int-based calls by routing them to
+ * small int wrappers (implemented in epoll_shim.c) that map int<->HANDLE via a table.
+ *
+ * struct epoll_event / epoll_data_t / EPOLL* constants come from wepoll.h.
+ */
+#ifndef WIN_EPOLL_SHIM_H
+#define WIN_EPOLL_SHIM_H
+
+#include "wepoll.h"   /* struct epoll_event, epoll_data_t, EPOLL* constants (HANDLE-based decls) */
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/* int-based wrappers readsb will actually call */
+int rsb_epoll_create(int size);
+int rsb_epoll_create1(int flags);
+int rsb_epoll_ctl(int epfd, int op, int sockfd, struct epoll_event *ev);
+int rsb_epoll_wait(int epfd, struct epoll_event *events, int maxevents, int timeout);
+int rsb_epoll_close(int epfd);   /* for the explicit close(net_epfd) site in net_io.c */
+
+#ifdef __cplusplus
+}
+#endif
+
+/* Route readsb's POSIX epoll names to our int wrappers. (Placed AFTER wepoll.h so its
+ * HANDLE-based declarations are parsed first; readsb call-sites get the macro form.) */
+#define epoll_create   rsb_epoll_create
+#define epoll_create1  rsb_epoll_create1
+#define epoll_ctl      rsb_epoll_ctl
+#define epoll_wait     rsb_epoll_wait
+
+#endif /* WIN_EPOLL_SHIM_H */
