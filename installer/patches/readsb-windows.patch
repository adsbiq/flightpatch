diff --git a/compat/windows/mman_compat.h b/compat/windows/mman_compat.h
new file mode 100644
index 0000000..4913b30
--- /dev/null
+++ b/compat/windows/mman_compat.h
@@ -0,0 +1,36 @@
+/*
+ * compat/windows/mman_compat.h — minimal mmap/munmap for native Windows (mingw).
+ * readsb only uses anonymous private mappings (MAP_ANONYMOUS|MAP_PRIVATE) as plain
+ * zeroed memory, so we back them with calloc/free. PROT_* are advisory here.
+ */
+#ifndef WIN_MMAN_COMPAT_H
+#define WIN_MMAN_COMPAT_H
+
+#include <stdlib.h>
+#include <string.h>
+#include <stdint.h>
+
+#define PROT_NONE  0x0
+#define PROT_READ  0x1
+#define PROT_WRITE 0x2
+#define PROT_EXEC  0x4
+
+#define MAP_SHARED    0x01
+#define MAP_PRIVATE   0x02
+#define MAP_ANONYMOUS 0x20
+#define MAP_ANON      MAP_ANONYMOUS
+#define MAP_FAILED    ((void *) -1)
+
+static inline void *mmap(void *addr, size_t length, int prot, int flags, int fd, long offset) {
+	(void) addr; (void) prot; (void) flags; (void) fd; (void) offset;
+	void *p = calloc(1, length ? length : 1); // anonymous zeroed memory
+	return p ? p : MAP_FAILED;
+}
+
+static inline int munmap(void *addr, size_t length) {
+	(void) length;
+	free(addr);
+	return 0;
+}
+
+#endif /* WIN_MMAN_COMPAT_H */
diff --git a/compat/windows/net_compat.h b/compat/windows/net_compat.h
new file mode 100644
index 0000000..928ec48
--- /dev/null
+++ b/compat/windows/net_compat.h
@@ -0,0 +1,136 @@
+/*
+ * compat/windows/net_compat.h — global-safe winsock types/init/constants for readsb.
+ * Included everywhere (via compat/compat.h). Provides Windows socket headers, one-time
+ * WSAStartup, POSIX socket constants Windows lacks, an errno mapper, and inline socket
+ * op helpers. Does NOT redefine close/read/write (that is win_sockops.h, per-file only),
+ * so file I/O in non-network TUs is unaffected.
+ */
+#ifndef WIN_NET_COMPAT_H
+#define WIN_NET_COMPAT_H
+
+#ifndef WIN32_LEAN_AND_MEAN
+#define WIN32_LEAN_AND_MEAN
+#endif
+#include <winsock2.h>
+#include <ws2tcpip.h>
+#if defined(__has_include)
+#  if __has_include(<afunix.h>)
+#    include <afunix.h>   /* AF_UNIX / sockaddr_un on Win10+ */
+#  endif
+#endif
+#include <windows.h>
+#include <errno.h>
+#include <stdint.h>
+#include <string.h>
+
+/* POSIX bits Windows names differently / lacks */
+#ifndef MSG_NOSIGNAL
+#define MSG_NOSIGNAL 0
+#endif
+#ifndef SHUT_RD
+#define SHUT_RD   SD_RECEIVE
+#define SHUT_WR   SD_SEND
+#define SHUT_RDWR SD_BOTH
+#endif
+#ifndef SOCK_NONBLOCK
+#define SOCK_NONBLOCK 0x4000   /* handled by our create helper, not passed to socket() */
+#endif
+#ifndef SOCK_CLOEXEC
+#define SOCK_CLOEXEC 0
+#endif
+#ifndef SOL_TCP
+#define SOL_TCP IPPROTO_TCP
+#endif
+/* Linux-only tuning knobs readsb may reference — no-op on Windows */
+#ifndef TCP_QUICKACK
+#define TCP_QUICKACK 12
+#endif
+#ifndef O_NONBLOCK
+#define O_NONBLOCK 0x800
+#endif
+
+/* winsock uses its own error codes; map the ones readsb tests against errno. */
+static inline int wsa_to_errno(int e) {
+    switch (e) {
+        case WSAEWOULDBLOCK: return EAGAIN;
+        case WSAEINPROGRESS: return EINPROGRESS;
+        case WSAEALREADY:    return EALREADY;
+        case WSAEINTR:       return EINTR;
+        case WSAECONNRESET:  return ECONNRESET;
+        case WSAECONNREFUSED:return ECONNREFUSED;
+        case WSAENOTCONN:    return ENOTCONN;
+        case WSAETIMEDOUT:   return ETIMEDOUT;
+        case WSAEADDRINUSE:  return EADDRINUSE;
+        default:             return e ? EIO : 0;
+    }
+}
+
+/* WSAStartup runs from compat/windows/net_init.c (a real linked TU with a constructor).
+ * A static-inline constructor in this header gets discarded, so winsock never inits and
+ * socket() fails with "creating socket: No error". */
+void win_net_init(void);
+
+/* socket() wrapper: (1) ensure WSAStartup; (2) STRIP the Linux-only SOCK_NONBLOCK/SOCK_CLOEXEC
+ * flags that readsb OR's into the type (Windows socket() rejects them as an invalid type — the
+ * real cause of "creating socket: No error"), applying non-blocking via ioctlsocket instead;
+ * (3) set errno on failure (winsock doesn't). */
+static inline int win_socket(int domain, int type, int protocol) {
+	win_net_init();
+	int want_nonblock = type & SOCK_NONBLOCK;
+	type &= ~(SOCK_NONBLOCK | SOCK_CLOEXEC);
+	SOCKET s = socket(domain, type, protocol);
+	if (s == INVALID_SOCKET) { errno = wsa_to_errno(WSAGetLastError()); return -1; }
+	if (want_nonblock) { u_long m = 1; ioctlsocket(s, FIONBIO, &m); }
+	return (int) s;
+}
+#define socket(d, t, p) win_socket((d), (t), (p))
+
+/* socket op helpers used by win_sockops.h (errno-setting like POSIX) */
+static inline int win_closesocket(int fd) { int r = closesocket((SOCKET) (uintptr_t) fd); if (r) errno = wsa_to_errno(WSAGetLastError()); return r; }
+static inline long win_recv(int fd, void *buf, size_t n) { int r = recv((SOCKET) (uintptr_t) fd, (char *) buf, (int) n, 0); if (r < 0) errno = wsa_to_errno(WSAGetLastError()); return r; }
+static inline long win_send(int fd, const void *buf, size_t n) { int r = send((SOCKET) (uintptr_t) fd, (const char *) buf, (int) n, MSG_NOSIGNAL); if (r < 0) errno = wsa_to_errno(WSAGetLastError()); return r; }
+static inline int win_set_nonblock(int fd) { u_long m = 1; int r = ioctlsocket((SOCKET) (uintptr_t) fd, FIONBIO, &m); if (r) errno = wsa_to_errno(WSAGetLastError()); return r; }
+
+/* setsockopt/getsockopt take const char* on Windows (const void* on POSIX) → wrap. */
+static inline int win_setsockopt(int s, int lvl, int opt, const void *val, int len) {
+	int r = setsockopt((SOCKET) (uintptr_t) s, lvl, opt, (const char *) val, len);
+	if (r) errno = wsa_to_errno(WSAGetLastError());
+	return r;
+}
+static inline int win_getsockopt(int s, int lvl, int opt, void *val, int *len) {
+	int r = getsockopt((SOCKET) (uintptr_t) s, lvl, opt, (char *) val, len);
+	if (r) errno = wsa_to_errno(WSAGetLastError());
+	return r;
+}
+#define setsockopt(s, l, o, v, n) win_setsockopt((s), (l), (o), (v), (n))
+#define getsockopt(s, l, o, v, n) win_getsockopt((s), (l), (o), (v), (n))
+
+/* connect() wrapper: winsock never sets errno, AND a non-blocking connect returns
+ * WSAEWOULDBLOCK where POSIX returns EINPROGRESS. readsb's outbound connector
+ * (anetTcpNonBlockConnect) tests `errno == EINPROGRESS`, so without this the feed
+ * connect to feed.adsbiq.com fails with a stale "Invalid argument". */
+static inline int win_connect(int s, const struct sockaddr *addr, socklen_t len) {
+	int r = connect((SOCKET) (uintptr_t) s, addr, (int) len);
+	if (r) {
+		int e = WSAGetLastError();
+		errno = (e == WSAEWOULDBLOCK) ? EINPROGRESS : wsa_to_errno(e);
+	}
+	return r;
+}
+#define connect(s, a, l) win_connect((s), (a), (l))
+
+/* accept4 is a Linux extension: accept + optional SOCK_NONBLOCK. */
+static inline int win_accept4(int fd, struct sockaddr *a, socklen_t *l, int flags) {
+	SOCKET c = accept((SOCKET) (uintptr_t) fd, a, l);
+	if (c == INVALID_SOCKET) { errno = wsa_to_errno(WSAGetLastError()); return -1; }
+	if (flags & SOCK_NONBLOCK) { u_long m = 1; ioctlsocket(c, FIONBIO, &m); }
+	return (int) c;
+}
+#define accept4(fd, a, l, flags) win_accept4((fd), (a), (l), (flags))
+
+/* generic ioctl() stub — readsb only calls ioctl() for serial (sdr_beast.c), which is
+ * non-functional on Windows; socket ioctls go through ioctlsocket above. */
+static inline int win_ioctl(int fd, unsigned long req, ...) { (void) fd; (void) req; return 0; }
+#define ioctl win_ioctl
+
+#endif /* WIN_NET_COMPAT_H */
diff --git a/compat/windows/net_init.c b/compat/windows/net_init.c
